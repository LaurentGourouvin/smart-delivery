              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Maison\",\n  \"street\": \"1 rue de la Paix\",\n  \"city\": \"Bordeaux\",\n  \"postalCode\": \"33000\",\n  \"country\": \"FR\",\n  \"isDefault\": true\n}"
            },
            "url": {
              "raw": "{{user_service}}/api/users/me/addresses",
              "host": ["{{user_service}}"],
              "path": ["api", "users", "me", "addresses"]
            }
          },
          "response": []
